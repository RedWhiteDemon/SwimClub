PORT=3000

# PostgreSQL (обязательно для API). Пример:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/swimclub
# или без URL: PGUSER=postgres PGDATABASE=swimclub PGPASSWORD=...
DATABASE_URL=postgresql://app:app123@localhost:5432/app_db

# Необязательно: если не задано, при первом запуске создаётся server/data/.jwt-secret
JWT_SECRET=

# Если в данных ещё нет пользователей — будет создан один админ (опционально)
SEED_ADMIN_EMAIL=ilyahappy1967@gmail.com
SEED_ADMIN_PASSWORD=23121967

# Электронная почта первого зарегистрированного пользователя получит роль admin,
# если совпадёт с этим значением (и до этого не было seed-админа).
ADMIN_EMAIL=ilyahappy1967@gmail.com

# Синоним для пароля seed-админа
ADMIN_PASSWORD=23121967

# --- Почта (восстановление пароля) ---
# Без SMTP письма не уходят на ящик: API всё равно отвечает «успех» (так устроено
# для безопасности), а ссылка сброса выводится только в консоль, где запущен сервер.
#
# Нужны транспорт И адрес отправителя (SMTP_FROM или SMTP_USER).
#
# Вариант 1 — одной строкой (пароль в URL лучше кодировать):
# SMTP_URL=smtps://user%40mail.com:password@smtp.example.com:465
# SMTP_FROM="SwimClub <noreply@example.com>"
#
# Вариант 2 — отдельные поля:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=user@example.com
# SMTP_PASS=
# SMTP_FROM="SwimClub <user@example.com>"
#
# Ссылка в письме ведёт на ваш сайт; для продакшена задайте публичный URL:
# PUBLIC_APP_URL=https://ваш-домен.example
#
# Опционально: исчезновение письма в спам, ответный адрес
# SMTP_REPLY_TO=support@example.com
